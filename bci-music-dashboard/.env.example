# Host ports
FRONTEND_PORT=5173
BACKEND_PORT=8001
BCI_INPUT_OSC_PORT=8000

# Application input
BCI_INPUT_OSC_IP=0.0.0.0
SESSION_KEYWORD=BCI

# Host directory mounted read-only/read-write into /xdf-records.
# Windows example: C:/Users/SJTU/.leaf/record
# macOS example: /Users/yourname/.leaf/record
HOST_XDF_ROOT_DIR=./xdf-records

# Output OSC runs on the host machine (Max/MSP, TouchDesigner, etc.).
# host.docker.internal works with Docker Desktop and this Compose file.
DEFAULT_OUTPUT_OSC_IP=host.docker.internal
DEFAULT_OUTPUT_OSC_PORT=57120

# Image tag used by online builds and offline image bundles.
BCI_IMAGE_TAG=latest
