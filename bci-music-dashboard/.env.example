# Host ports
FRONTEND_PORT=5173
BACKEND_PORT=8001
BCI_INPUT_OSC_PORT=8000

# Application input
BCI_INPUT_OSC_IP=0.0.0.0
SESSION_KEYWORD=BCI

# Host directory mounted read-only/read-write into /xdf-records.
# Windows example: C:/Users/SJTU/.leaf/record
# macOS example: /Users/yourname/.leaf/record
HOST_XDF_ROOT_DIR=./xdf-records

# Output OSC runs on the host machine (Max/MSP, TouchDesigner, etc.).
# host.docker.internal works with Docker Desktop and this Compose file.
DEFAULT_OUTPUT_OSC_IP=host.docker.internal
DEFAULT_OUTPUT_OSC_PORT=57120

# Image tag used by online builds and offline image bundles.
BCI_IMAGE_TAG=latest

# Optional local melody model. Native macOS is the primary inference target.
MUSIC_MODEL_PROVIDER=auto
MUSIC_MODEL_PATH=models/music/latest.pt
MUSIC_MODEL_CONFIG_PATH=models/music/model_config.json

# Notochord provider. "auto" prefers Notochord when this checkpoint and the
# Python package are available, then tries the local Transformer checkpoint.
NOTOCHORD_CHECKPOINT=~/Library/Application Support/Notochord/notochord-latest.ckpt
NOTOCHORD_DEVICE=cpu
# General MIDI instrument number (1-based). 14 = Xylophone.
NOTOCHORD_INSTRUMENT=14
MUSIC_LIBRARY_PATH=music_library
